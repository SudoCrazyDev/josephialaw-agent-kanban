# =========================================================================
# Supabase Cloud
# =========================================================================

# --- server-only (service role) -----------------------------------------
# Used by Next.js route handlers and the MCP server. Bypasses RLS.
# Never expose to the browser.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=eyJ...service_role_key...

# --- browser-safe (anon) ------------------------------------------------
# Used by the board UI for reads + realtime subscriptions.
# Subject to RLS policies defined in supabase/migrations/0002_rls.sql.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_key...

# =========================================================================
# App
# =========================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================================================================
# MCP
# =========================================================================
# Extra entropy mixed into agent bearer-token hashing.
MCP_TOKEN_PEPPER=change-me-in-production

# =========================================================================
# Auth — Sign in with Google (direct OAuth, no Supabase Auth)
# =========================================================================
# From Google Cloud Console → APIs & Services → Credentials →
#   Create OAuth 2.0 Client ID (Web application)
#   Authorized JavaScript origins:
#     https://kanban.divorcewithaplan.com
#     http://localhost:3000
#   Authorized redirect URIs:
#     https://kanban.divorcewithaplan.com/api/auth/callback/google
#     http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# 32+ random bytes used to sign the session JWT.
# Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string

# Optional allow-list. Leave both blank to allow any verified Google account.
# Set at least one in production.
AUTH_ALLOWED_DOMAINS=josephialaw.com
AUTH_ALLOWED_EMAILS=

# =========================================================================
# Cron
# =========================================================================
# Bearer token for the /api/cron/release-stale endpoint (and any future cron
# routes). Schedule this endpoint externally — pg_cron, Vercel Cron, GitHub
# Actions scheduled workflow, Upstash QStash, etc. Example:
#   curl -H "Authorization: Bearer $CRON_SECRET" \
#        https://kanban.divorcewithaplan.com/api/cron/release-stale
CRON_SECRET=change-me-to-a-long-random-string
